      "name": "Auth",
      "item": [
        {
          "name": "Register user",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var ts = Date.now();",
                  "pm.environment.set('user_email', 'user-' + ts + '@example.com');",
                  "pm.environment.set('user_username', 'Test User');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var j = pm.response.json();",
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('No user data or token leaked', () => {",
                  "    pm.expect(j.success).to.eq(true);",
                  "    pm.expect(j).to.not.have.property('data');",
                  "    pm.expect(j).to.not.have.property('token');",
                  "});",
                  "if (pm.response.code === 201 && j.user_id) {",
                  "    pm.environment.set('user_id', j.user_id + '');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"{{user_username}}\",\"email\":\"{{user_email}}\",\"password\":\"StrongP@ss1\"}"
            },
            "url": {
              "raw": "{{scheme}}://{{host}}:{{port}}/api/register",
              "protocol": "{{scheme}}",
              "host": [
                "{{host}}"
              ],
              "port": "{{port}}",
              "path": [
